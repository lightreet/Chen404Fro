# 开发环境配置示例
# 复制此文件为 .env.development 和 .env.production 并修改相应值

# API 基础地址
VITE_API_BASE_URL=http://localhost:10404/api

# 图片基础地址（用于拼接图片URL）
VITE_IMAGE_BASE_URL=http://localhost:10404

# 应用标题
VITE_APP_TITLE=Chen404 Blog

# 应用版本
VITE_APP_VERSION=1.0.0

# 高德地图 JS API Key（旅行纪念地图使用）
VITE_AMAP_KEY=

# 高德地图安全密钥（如控制台已启用安全校验可配置）
VITE_AMAP_SECURITY_CODE=

# 后端 LLM 配置请在服务端环境变量中设置
# LLM_ENABLED=true
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://yunwu.ai/v1
# LLM_API_STYLE=chat-completions
# LLM_MODEL=gpt-4o
